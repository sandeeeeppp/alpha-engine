# Alpha Engine — Environment Variable Template
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to version control.

# ── LLM Providers ─────────────────────────────────────────────
# Groq API key — used by the Supervisor LLM (llama-3.1-8b-instant)
GROQ_API_KEY=gsk_your_groq_key_here

# Google AI API key — used for embeddings (text-embedding-004) and Synthesizer (gemini-2.5-flash)
GEMINI_API_KEY=AIzaSy_your_gemini_key_here

# ── Vector Store ───────────────────────────────────────────────
# Pinecone API key
PINECONE_API_KEY=pcsk_your_pinecone_key_here

# Name of your Pinecone serverless index (must already exist)
PINECONE_INDEX_NAME=alpha-engine

# ── Internal Security ──────────────────────────────────────────
# Shared secret used to authenticate the /api/ingest endpoint.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_SECRET=your_random_secret_here

# ── Frontend (CORS) ────────────────────────────────────────────
# Origin of the Next.js frontend. Used to configure CORS on the backend.
# Default for local dev: http://localhost:3000
# Set to your Vercel deployment URL in production.
VERCEL_FRONTEND_URL=http://localhost:3000
